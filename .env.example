# ==========================================================
# SocioMonkey Backend - Environment Template
# ==========================================================

# Runtime profile: development | production | testing
APP_ENV=production
FLASK_ENV=production

# Local run bind settings (used by run.py)
FLASK_HOST=0.0.0.0
FLASK_PORT=5002

# Flask/JWT secret (required in production)
SECRET_KEY=replace-with-a-long-random-secret

# Database
# Local dev example:
# DATABASE_URL=sqlite:///mvp.db
# Neon production example:
# DATABASE_URL=postgresql://username:password@host/database?sslmode=require
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# Auth/session settings
JWT_EXPIRY_MINUTES=1440

# Comma-separated list of allowed frontend origins
# Example: https://app.sociomonkey.com,https://sociomonkey-ai.vercel.app
CORS_ORIGINS=https://app.sociomonkey.com,https://sociomonkey-ai.vercel.app

# Optional OTP email settings
SMTP_USER=
SMTP_PASSWORD=
