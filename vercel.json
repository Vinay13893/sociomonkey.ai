{
  "version": 2,
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/internal/reminders/process",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/internal/jobs/process",
      "schedule": "15 2 * * *"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
